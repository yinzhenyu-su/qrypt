{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/yinzhenyu/qrypt/qrypt.schema.json",
  "title": "Qrypt",
  "description": "Configuration schema for qrypt — an encrypted virtual filesystem for cloud drives.",
  "type": "object",
  "properties": {
    "version": {
      "description": "Config format version. Currently only \"1\" is recognised.",
      "type": "string",
      "default": "1",
      "x-taplo": {
        "hidden": true
      }
    },
    "mount_point": {
      "description": "FUSE mount point (e.g. ~/Qrypt).",
      "type": "string",
      "default": "~/Qrypt"
    },
    "cache_dir": {
      "description": "Directory for read cache and pending upload staging.",
      "type": "string",
      "default": "~/.qrypt/qrypt-cache"
    },
    "volume_name": {
      "description": "Volume label shown in the OS file manager.",
      "type": "string",
      "default": "Qrypt"
    },
    "no_apple_double": {
      "description": "Skip writing Apple Double (._) metadata files on macOS.",
      "type": "boolean",
      "default": true
    },
    "no_apple_xattr": {
      "description": "Ignore com.apple.* extended attributes on macOS.",
      "type": "boolean",
      "default": false
    },
    "read_only": {
      "description": "Mount the filesystem read-only.",
      "type": "boolean",
      "default": false
    },
    "allow_other": {
      "description": "Allow other local users to access the FUSE mount.",
      "type": "boolean",
      "default": false
    },
    "default_permissions": {
      "description": "Ask the kernel to enforce mode/uid/gid permissions.",
      "type": "boolean",
      "default": false
    },
    "attr_timeout": {
      "description": "FUSE attribute cache timeout (e.g. \"1s\", \"500ms\", \"0s\").",
      "type": "string",
      "default": "1s"
    },
    "entry_timeout": {
      "description": "FUSE entry cache timeout (e.g. \"1s\", \"500ms\", \"0s\").",
      "type": "string",
      "default": "1s"
    },
    "negative_timeout": {
      "description": "FUSE negative lookup cache timeout (e.g. \"0s\", \"1s\").",
      "type": "string",
      "default": "0s"
    },
    "total_space": {
      "description": "Total capacity reported to the OS (e.g. \"1T\", \"500G\").",
      "type": "string",
      "default": "1T",
      "pattern": "^\\d+[KMGTP]?$|^\\d+$"
    },
    "free_space": {
      "description": "Free space reported to the OS (e.g. \"800G\").",
      "type": "string",
      "default": "800G",
      "pattern": "^\\d+[KMGTP]?$|^\\d+$"
    },
    "encryption": {
      "$ref": "#/definitions/encryptionConfig"
    },
    "defaults": {
      "type": "object",
      "description": "Default values inherited by every mount unless overridden.",
      "properties": {
        "encryption": {
          "$ref": "#/definitions/encryptionConfig"
        },
        "cache": {
          "$ref": "#/definitions/cacheConfig"
        }
      },
      "additionalProperties": false
    },
    "logging": {
      "$ref": "#/definitions/loggingConfig"
    },
    "bandwidth": {
      "$ref": "#/definitions/bandwidthConfig"
    },
    "mounts": {
      "description": "List of cloud-drive mounts exposed under the mount point.",
      "type": "array",
      "items": {
        "$ref": "#/definitions/mountConfig"
      }
    }
  },
  "additionalProperties": false,
  "definitions": {
    "encryptionConfig": {
      "type": "object",
      "description": "rclone-compatible encryption settings.",
      "properties": {
        "password": {
          "description": "Encryption password.",
          "type": "string",
          "minLength": 1
        },
        "salt": {
          "description": "Encryption salt (empty = derive from password).",
          "type": "string",
          "default": ""
        },
        "filename_encryption": {
          "description": "File-name encryption mode.",
          "type": "string",
          "default": "standard",
          "enum": ["standard", "off", "obfuscate"]
        },
        "filename_encoding": {
          "description": "Encoding for encrypted file names.",
          "type": "string",
          "default": "base32",
          "enum": ["base32", "base64"]
        }
      },
      "additionalProperties": false
    },
    "cacheConfig": {
      "type": "object",
      "description": "Per-mount (or default) cache settings.",
      "properties": {
        "dir": {
          "description": "Cache directory for this mount. Falls back to cache_dir/<mount_name>.",
          "type": "string"
        },
        "max_size": {
          "description": "Maximum read-cache size (e.g. \"512M\", \"2G\", \"1T\").",
          "type": "string",
          "default": "512M",
          "pattern": "^\\d+[KMGTP]?$|^\\d+$"
        },
        "upload_delay": {
          "description": "Debounce delay before flushing a new file to the cloud (e.g. \"5s\", \"1m\").",
          "type": "string",
          "default": "0s"
        },
        "upload_workers": {
          "description": "Number of concurrent upload workers per mount.",
          "type": "integer",
          "default": 4,
          "minimum": 0
        },
        "delete_delay": {
          "description": "Debounce delay before deleting a file from the cloud (e.g. \"2s\").",
          "type": "string",
          "default": "0s"
        }
      },
      "additionalProperties": false
    },
    "loggingConfig": {
      "type": "object",
      "description": "Logging settings.",
      "properties": {
        "log_level": {
          "description": "Minimum log level to emit.",
          "type": "string",
          "default": "info",
          "enum": ["debug", "info", "warn", "error", "off"]
        },
        "log_file": {
          "description": "Path to the main log file.",
          "type": "string"
        },
        "error_file": {
          "description": "Path to the error log file (falls back to <log_file>-err.log).",
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "bandwidthConfig": {
      "type": "object",
      "description": "Per-direction bandwidth limits.",
      "properties": {
        "download": {
          "description": "Download speed cap (e.g. \"10Mbps\", \"5MB/s\", empty = unlimited).",
          "type": "string",
          "default": ""
        },
        "upload": {
          "description": "Upload speed cap (e.g. \"2Mbps\", empty = unlimited).",
          "type": "string",
          "default": ""
        }
      },
      "additionalProperties": false
    },
    "mountConfig": {
      "type": "object",
      "description": "A single cloud-drive mount.",
      "properties": {
        "name": {
          "description": "Mount name — used as the directory name under the mount point.",
          "type": "string",
          "minLength": 1
        },
        "type": {
          "description": "Backend driver type.",
          "type": "string",
          "enum": ["localfs", "quark", "139yun", "115", "aliyundrive", "webdav"]
        },
        "mount_point": {
          "description": "Deprecated. Use the top-level mount_point instead.",
          "type": "string"
        },
        "params": {
          "description": "Driver-specific key/value parameters (e.g. cookie, root_path, root).",
          "type": "object",
          "patternProperties": {
            "^.*$": {
              "type": "string"
            }
          },
          "minProperties": 1,
          "additionalProperties": false
        },
        "encryption": {
          "$ref": "#/definitions/encryptionConfig"
        },
        "cache": {
          "$ref": "#/definitions/cacheConfig"
        }
      },
      "required": ["name", "type"],
      "allOf": [
        {
          "if": {
            "properties": { "type": { "const": "aliyundrive" } },
            "required": ["type"]
          },
          "then": {
            "required": ["params"],
            "properties": {
              "params": {
                "required": ["refresh_token", "drive_id", "root_id"],
                "properties": {
                  "refresh_token": {
                    "description": "Aliyun Drive refresh token.",
                    "type": "string", "minLength": 1
                  },
                  "drive_id": {
                    "description": "Aliyun Drive drive ID.",
                    "type": "string", "minLength": 1
                  },
                  "root_id": {
                    "description": "Aliyun Drive root folder file ID for this mount.",
                    "type": "string", "minLength": 1
                  },
                  "root_path": {
                    "description": "Optional path resolved under root_id during startup.",
                    "type": "string"
                  },
                  "order_by": {
                    "description": "List ordering field.",
                    "type": "string",
                    "enum": ["name", "size", "updated_at", "created_at"]
                  },
                  "order_direction": {
                    "description": "List ordering direction.",
                    "type": "string",
                    "enum": ["ASC", "DESC"]
                  },
                  "api_base_url": {
                    "description": "Override Aliyun API base URL for tests.",
                    "type": "string"
                  },
                  "auth_url": {
                    "description": "Override Aliyun auth URL for tests.",
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": { "type": { "const": "localfs" } },
            "required": ["type"]
          },
          "then": {
            "required": ["params"],
            "properties": {
              "params": {
                "required": ["root"],
                "properties": {
                  "root": {
                    "description": "Local filesystem directory path.",
                    "type": "string", "minLength": 1
                  },
                  "local_root": {
                    "description": "Alias for root (fallback if root is empty).",
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": { "type": { "const": "quark" } },
            "required": ["type"]
          },
          "then": {
            "required": ["params"],
            "properties": {
              "params": {
                "required": ["cookie"],
                "properties": {
                  "cookie": {
                    "description": "Quark cloud drive authentication cookie.",
                    "type": "string", "minLength": 1
                  },
                  "root_path": {
                    "description": "Virtual root path on the drive.",
                    "type": "string"
                  },
                  "root_id": {
                    "description": "Root directory ID.",
                    "type": "string"
                  },
                  "base_url": {
                    "description": "Custom API base URL.",
                    "type": "string"
                  },
                  "v2_url": {
                    "description": "Custom API v2 URL.",
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": { "type": { "const": "115" } },
            "required": ["type"]
          },
          "then": {
            "required": ["params"],
            "properties": {
              "params": {
                "required": ["cookie"],
                "properties": {
                  "cookie": {
                    "description": "115 cloud drive authentication cookie.",
                    "type": "string", "minLength": 1
                  },
                  "root_id": {
                    "description": "Root directory ID.",
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": { "type": { "const": "139yun" } },
            "required": ["type"]
          },
          "then": {
            "required": ["params"],
            "properties": {
              "params": {
                "required": ["authorization"],
                "properties": {
                  "authorization": {
                    "description": "139 cloud drive authorization token.",
                    "type": "string", "minLength": 1
                  },
                  "root_id": {
                    "description": "Root directory ID.",
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": { "type": { "const": "webdav" } },
            "required": ["type"]
          },
          "then": {
            "required": ["params"],
            "properties": {
              "params": {
                "required": ["url", "username", "password"],
                "properties": {
                  "url": {
                    "description": "WebDAV server base URL.",
                    "type": "string", "minLength": 1,
                    "example": "https://nextcloud.example.com/remote.php/dav/files/user"
                  },
                  "username": {
                    "description": "WebDAV authentication username.",
                    "type": "string", "minLength": 1
                  },
                  "password": {
                    "description": "WebDAV authentication password or app token.",
                    "type": "string", "minLength": 1
                  },
                  "root_path": {
                    "description": "Optional path under the WebDAV base URL used as this mount root.",
                    "type": "string"
                  }
                }
              }
            }
          }
        }
      ],
      "additionalProperties": false
    }
  }
}
