{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/yinzhenyu/qrypt/qrypt.schema.json",
  "title": "Qrypt",
  "description": "Configuration schema for qrypt — an encrypted virtual filesystem for cloud drives.",
  "type": "object",
  "properties": {
    "version": {
      "description": "Config format version. Currently only \"1\" is recognised.",
      "type": "string",
      "enum": ["1"],
      "default": "1",
      "x-taplo": {
        "hidden": true
      }
    },
    "mount_point": {
      "description": "FUSE mount point (e.g. ~/Qrypt).",
      "type": "string",
      "default": "~/Qrypt"
    },
    "cache_dir": {
      "description": "Directory for read cache and pending upload staging.",
      "type": "string",
      "default": "~/.qrypt/qrypt-cache"
    },
    "volume_name": {
      "description": "Volume label shown in the OS file manager.",
      "type": "string",
      "default": "Qrypt"
    },
    "no_apple_double": {
      "description": "Skip writing Apple Double (._) metadata files on macOS.",
      "type": "boolean",
      "default": true
    },
    "no_apple_xattr": {
      "description": "Ignore com.apple.* extended attributes on macOS.",
      "type": "boolean",
      "default": false
    },
    "read_only": {
      "description": "Mount the filesystem read-only.",
      "type": "boolean",
      "default": false
    },
    "allow_other": {
      "description": "Allow other local users to access the FUSE mount.",
      "type": "boolean",
      "default": false
    },
    "default_permissions": {
      "description": "Ask the kernel to enforce mode/uid/gid permissions.",
      "type": "boolean",
      "default": false
    },
    "attr_timeout": {
      "description": "FUSE attribute cache timeout (e.g. \"1s\", \"500ms\", \"0s\").",
      "type": "string",
      "default": "1s"
    },
    "entry_timeout": {
      "description": "FUSE entry cache timeout (e.g. \"1s\", \"500ms\", \"0s\").",
      "type": "string",
      "default": "1s"
    },
    "negative_timeout": {
      "description": "FUSE negative lookup cache timeout (e.g. \"0s\", \"1s\").",
      "type": "string",
      "default": "0s"
    },
    "total_space": {
      "description": "Total capacity reported to the OS (e.g. \"1T\", \"500G\").",
      "type": "string",
      "default": "1T",
      "pattern": "^\\d+[KMGTP]?$|^\\d+$"
    },
    "free_space": {
      "description": "Free space reported to the OS (e.g. \"800G\").",
      "type": "string",
      "default": "800G",
      "pattern": "^\\d+[KMGTP]?$|^\\d+$"
    },
    "encryption": {
      "$ref": "#/definitions/encryptionConfig"
    },
    "defaults": {
      "type": "object",
      "description": "Default values inherited by every mount unless overridden.",
      "properties": {
        "encryption": {
          "$ref": "#/definitions/encryptionConfig"
        },
        "cache": {
          "$ref": "#/definitions/cacheConfig"
        }
      },
      "additionalProperties": false
    },
    "logging": {
      "$ref": "#/definitions/loggingConfig"
    },
    "time": {
      "$ref": "#/definitions/timeConfig"
    },
    "bandwidth": {
      "$ref": "#/definitions/bandwidthConfig"
    },
    "mounts": {
      "description": "List of cloud-drive mounts exposed under the mount point.",
      "type": "array",
      "items": {
        "$ref": "#/definitions/mountConfig"
      }
    }
  },
  "additionalProperties": false,
  "definitions": {
    "encryptionConfig": {
      "type": "object",
      "description": "rclone-compatible encryption settings.",
      "properties": {
        "password": {
          "description": "Encryption password.",
          "type": "string",
          "minLength": 1
        },
        "salt": {
          "description": "Encryption salt (empty = derive from password).",
          "type": "string",
          "default": ""
        },
        "password_obscured": {
          "description": "Set true when password is copied from rclone's obscured config value.",
          "type": "boolean",
          "default": false
        },
        "salt_obscured": {
          "description": "Set true when salt is copied from rclone's obscured password2 config value.",
          "type": "boolean",
          "default": false
        },
        "filename_encryption": {
          "description": "File-name encryption mode.",
          "type": "string",
          "default": "standard",
          "enum": ["standard", "off", "obfuscate"]
        },
        "filename_encoding": {
          "description": "Encoding for encrypted file names.",
          "type": "string",
          "default": "base32",
          "enum": ["base32", "base64"]
        }
      },
      "additionalProperties": false
    },
    "cacheConfig": {
      "type": "object",
      "description": "Per-mount (or default) cache settings.",
      "properties": {
        "dir": {
          "description": "Cache directory for this mount. Falls back to cache_dir/<mount_name>.",
          "type": "string"
        },
        "max_size": {
          "description": "Maximum read-cache size (e.g. \"512M\", \"2G\", \"1T\").",
          "type": "string",
          "default": "512M",
          "pattern": "^\\d+[KMGTP]?$|^\\d+$"
        },
        "upload_delay": {
          "description": "Debounce delay before flushing a new file to the cloud (e.g. \"5s\", \"1m\").",
          "type": "string",
          "default": "0s"
        },
        "upload_workers": {
          "description": "Number of concurrent upload workers per mount.",
          "type": "integer",
          "default": 4,
          "minimum": 0
        },
        "delete_delay": {
          "description": "Debounce delay before deleting a file from the cloud (e.g. \"2s\").",
          "type": "string",
          "default": "0s"
        }
      },
      "additionalProperties": false
    },
    "loggingConfig": {
      "type": "object",
      "description": "Logging settings.",
      "properties": {
        "log_level": {
          "description": "Minimum log level to emit.",
          "type": "string",
          "default": "info",
          "enum": ["debug", "info", "warn", "error", "off"]
        },
        "log_file": {
          "description": "Path to the main log file.",
          "type": "string"
        },
        "error_file": {
          "description": "Path to the error log file (falls back to <log_file>-err.log).",
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "timeConfig": {
      "type": "object",
      "description": "Time source settings. qrypt uses NTP timestamps when available and falls back to the system clock.",
      "properties": {
        "ntp_enabled": {
          "description": "Enable background NTP clock sync for operation timestamps.",
          "type": "boolean",
          "default": true
        },
        "ntp_servers": {
          "description": "NTP servers, including port.",
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": ["ntp1.aliyun.com:123", "ntp2.aliyun.com:123", "ntp1.tencent.com:123", "ntp2.tencent.com:123", "ntp1.ntsc.ac.cn:123", "ntp2.ntsc.ac.cn:123", "ntp1.cstnet.cn:123", "0.cn.pool.ntp.org:123", "time.cloudflare.com:123", "time.google.com:123"]
        },
        "ntp_timeout": {
          "description": "Per-server NTP timeout.",
          "type": "string",
          "default": "1500ms"
        },
        "ntp_poll_interval": {
          "description": "Background NTP refresh interval.",
          "type": "string",
          "default": "30m"
        }
      },
      "additionalProperties": false
    },
    "bandwidthConfig": {
      "type": "object",
      "description": "Per-direction bandwidth limits.",
      "properties": {
        "download": {
          "description": "Download speed cap (e.g. \"10Mbps\", \"5MB/s\", empty = unlimited).",
          "type": "string",
          "default": ""
        },
        "upload": {
          "description": "Upload speed cap (e.g. \"2Mbps\", empty = unlimited).",
          "type": "string",
          "default": ""
        }
      },
      "additionalProperties": false
    },
    "mountConfig": {
      "type": "object",
      "description": "A single cloud-drive mount.",
      "properties": {
        "name": {
          "description": "Mount name — used as the directory name under the mount point.",
          "type": "string",
          "minLength": 1
        },
        "type": {
          "description": "Backend driver type.",
          "type": "string",
          "enum": ["localfs", "quark", "yun139", "115", "189", "aliyundrive", "baidu_netdisk", "webdav", "s3"]
        },
        "params": {
          "description": "Driver-specific key/value parameters (e.g. cookie and root_path).",
          "type": "object",
          "patternProperties": {
            "^.*$": {
              "type": "string"
            }
          },
          "minProperties": 1,
          "additionalProperties": false
        },
        "encryption": {
          "$ref": "#/definitions/encryptionConfig"
        },
        "cache": {
          "$ref": "#/definitions/cacheConfig"
        }
      },
      "required": ["name", "type"],
      "allOf": [
        {
          "if": {
            "properties": { "type": { "const": "aliyundrive" } },
            "required": ["type"]
          },
          "then": {
            "required": ["params"],
            "properties": {
              "params": {
                "$ref": "#/definitions/aliyundriveParams"
              }
            }
          }
        },
        {
          "if": {
            "properties": { "type": { "const": "baidu_netdisk" } },
            "required": ["type"]
          },
          "then": {
            "required": ["params"],
            "properties": {
              "params": {
                "$ref": "#/definitions/baiduNetdiskParams"
              }
            }
          }
        },
        {
          "if": {
            "properties": { "type": { "const": "localfs" } },
            "required": ["type"]
          },
          "then": {
            "required": ["params"],
            "properties": {
              "params": {
                "$ref": "#/definitions/localfsParams"
              }
            }
          }
        },
        {
          "if": {
            "properties": { "type": { "const": "quark" } },
            "required": ["type"]
          },
          "then": {
            "required": ["params"],
            "properties": {
              "params": {
                "$ref": "#/definitions/quarkParams"
              }
            }
          }
        },
        {
          "if": {
            "properties": { "type": { "const": "115" } },
            "required": ["type"]
          },
          "then": {
            "required": ["params"],
            "properties": {
              "params": {
                "$ref": "#/definitions/p115Params"
              }
            }
          }
        },
        {
          "if": {
            "properties": { "type": { "const": "yun139" } },
            "required": ["type"]
          },
          "then": {
            "required": ["params"],
            "properties": {
              "params": {
                "$ref": "#/definitions/yun139Params"
              }
            }
          }
        },
        {
          "if": {
            "properties": { "type": { "const": "webdav" } },
            "required": ["type"]
          },
          "then": {
            "required": ["params"],
            "properties": {
              "params": {
                "$ref": "#/definitions/webdavParams"
              }
            }
          }
        },
        {
          "if": {
            "properties": { "type": { "const": "189" } },
            "required": ["type"]
          },
          "then": {
            "required": ["params"],
            "properties": {
              "params": {
                "$ref": "#/definitions/p189Params"
              }
            }
          }
        },
        {
          "if": {
            "properties": { "type": { "const": "s3" } },
            "required": ["type"]
          },
          "then": {
            "required": ["params"],
            "properties": {
              "params": {
                "$ref": "#/definitions/s3Params"
              }
            }
          }
        }
      ],
      "additionalProperties": false
    },
    "localfsParams": {
      "type": "object",
      "required": ["root_path"],
      "properties": {
        "root_path": {
          "description": "Local filesystem root directory path.",
          "type": "string", "minLength": 1,
          "x-example": "/tmp/qrypt-remote"
        }
      },
      "additionalProperties": false
    },
    "aliyundriveParams": {
      "type": "object",
      "required": ["refresh_token", "drive_id"],
      "properties": {
        "refresh_token": {
          "description": "Aliyun Drive refresh token for OAuth authentication.",
          "type": "string", "minLength": 1,
          "x-secret": true,
          "x-example": "your-refresh-token"
        },
        "drive_id": {
          "description": "Aliyun Drive drive ID.",
          "type": "string", "minLength": 1,
          "x-example": "your-drive-id"
        },
        "root_path": {
          "description": "Virtual root path, resolved to the provider folder ID at startup.",
          "type": "string",
          "default": "/",
          "x-example": "/qrypt"
        },
        "order_by": {
          "description": "File listing sort field.",
          "type": "string",
          "enum": ["name", "size", "updated_at", "created_at"],
          "x-example": "name"
        },
        "order_direction": {
          "description": "Sort direction (ASC or DESC).",
          "type": "string",
          "enum": ["ASC", "DESC"],
          "x-example": "ASC"
        },
        "api_base_url": {
          "description": "Custom API base URL.",
          "type": "string",
          "x-example": "https://openapi.alipan.com"
        },
        "auth_url": {
          "description": "Custom OAuth token URL.",
          "type": "string",
          "x-example": "https://openapi.alipan.com/oauth/authorize"
        }
      },
      "additionalProperties": false
    },
    "baiduNetdiskParams": {
      "type": "object",
      "required": ["refresh_token"],
      "properties": {
        "refresh_token": {
          "description": "Baidu Netdisk refresh token.",
          "type": "string", "minLength": 1,
          "x-secret": true,
          "x-example": "your-refresh-token"
        },
        "access_token": {
          "description": "Optional initial Baidu Netdisk access token; refreshed automatically when needed.",
          "type": "string",
          "x-secret": true
        },
        "root_path": {
          "description": "Baidu Netdisk path used as this mount root.",
          "type": "string",
          "default": "/",
          "x-example": "/qrypt"
        },
        "order_by": {
          "description": "List ordering field: name, time, or size.",
          "type": "string",
          "default": "name",
          "enum": ["name", "time", "size"]
        },
        "order_direction": {
          "description": "List ordering direction: asc or desc.",
          "type": "string",
          "default": "asc",
          "enum": ["asc", "desc"]
        },
        "use_online_api": {
          "description": "Use OpenList-compatible online token refresh API.",
          "type": "boolean",
          "default": true
        },
        "online_api": {
          "description": "Online token refresh API URL.",
          "type": "string",
          "x-example": "https://api.oplist.org/baiduyun/renewapi"
        },
        "upload_api": {
          "description": "Baidu PCS upload API base URL.",
          "type": "string",
          "x-example": "https://d.pcs.baidu.com"
        },
        "client_id": {
          "description": "Baidu app API Key used as OAuth client_id when use_online_api=false.",
          "type": "string",
          "x-secret": true
        },
        "client_secret": {
          "description": "Baidu app Secret Key used as OAuth client_secret when use_online_api=false.",
          "type": "string",
          "x-secret": true
        },
        "api_base_url": {
          "description": "Custom Baidu REST API base URL.",
          "type": "string",
          "x-example": "https://pan.baidu.com/rest/2.0"
        },
        "oauth_url": {
          "description": "Custom Baidu OAuth token URL.",
          "type": "string",
          "x-example": "https://openapi.baidu.com/oauth/2.0/token"
        },
        "download_user_agent": {
          "description": "User-Agent used for Baidu download requests.",
          "type": "string",
          "default": "pan.baidu.com"
        }
      },
      "additionalProperties": false
    },
    "quarkParams": {
      "type": "object",
      "required": ["cookie"],
      "properties": {
        "cookie": {
          "description": "Quark cloud drive authentication cookie.",
          "type": "string", "minLength": 1,
          "x-secret": true,
          "x-example": "k1=v1; k2=v2"
        },
        "root_path": {
          "description": "Virtual root path on the drive.",
          "type": "string",
          "default": "/",
          "x-example": "/qrypt"
        },
        "base_url": {
          "description": "Custom API base URL.",
          "type": "string",
          "x-example": "https://drive.quark.cn"
        },
        "v2_url": {
          "description": "Custom API v2 URL.",
          "type": "string",
          "x-example": "https://drive-m.quark.cn"
        }
      },
      "additionalProperties": false
    },
    "yun139Params": {
      "type": "object",
      "required": ["authorization"],
      "properties": {
        "authorization": {
          "description": "139 cloud drive authorization token.",
          "type": "string", "minLength": 1,
          "x-secret": true,
          "x-example": "your-authorization-token"
        },
        "root_path": {
          "description": "Virtual root path, resolved to the provider folder ID at startup.",
          "type": "string",
          "default": "/",
          "x-example": "/qrypt"
        },
        "root_id": {
          "description": "Pre-resolved folder ID (skips root_path resolution).",
          "type": "string",
          "x-example": "FtozqWiFB1yWOWUGc9oNCf6M0h5fRwcQl"
        }
      },
      "additionalProperties": false
    },
    "p115Params": {
      "type": "object",
      "required": ["cookie"],
      "properties": {
        "cookie": {
          "description": "115 cloud drive authentication cookie.",
          "type": "string", "minLength": 1,
          "x-secret": true,
          "x-example": "k1=v1; k2=v2"
        },
        "root_path": {
          "description": "Virtual root path, resolved to the provider folder ID at startup.",
          "type": "string",
          "default": "/",
          "x-example": "/qrypt"
        }
      },
      "additionalProperties": false
    },
    "p189Params": {
      "type": "object",
      "required": ["cookie"],
      "properties": {
        "cookie": {
          "description": "189 cloud drive authentication cookie.",
          "type": "string", "minLength": 1,
          "x-secret": true,
          "x-example": "k1=v1; k2=v2"
        },
        "root_path": {
          "description": "Virtual root path on the drive.",
          "type": "string",
          "default": "/",
          "x-example": "/qrypt"
        },
        "root_id": {
          "description": "Pre-resolved folder ID (skips root_path resolution).",
          "type": "string",
          "x-example": "-11"
        }
      },
      "additionalProperties": false
    },
    "webdavParams": {
      "type": "object",
      "required": ["url", "username", "password"],
      "properties": {
        "url": {
          "description": "WebDAV server base URL.",
          "type": "string", "minLength": 1,
          "example": "https://nextcloud.example.com/remote.php/dav/files/user"
        },
        "username": {
          "description": "WebDAV authentication username.",
          "type": "string", "minLength": 1,
          "x-example": "user"
        },
        "password": {
          "description": "WebDAV authentication password or app token.",
          "type": "string", "minLength": 1,
          "x-secret": true,
          "x-example": "your-password-or-app-token"
        },
        "root_path": {
          "description": "Optional path under the WebDAV base URL used as this mount root.",
          "type": "string",
          "default": "/",
          "x-example": "/qrypt"
        }
      },
      "additionalProperties": false
    },
    "s3Params": {
      "type": "object",
      "required": ["bucket", "endpoint", "access_key_id", "secret_access_key"],
      "properties": {
        "bucket": {
          "description": "S3 bucket name.",
          "type": "string", "minLength": 1,
          "x-example": "my-bucket"
        },
        "endpoint": {
          "description": "S3 endpoint URL.",
          "type": "string", "minLength": 1,
          "example": "https://s3.us-east-1.amazonaws.com"
        },
        "region": {
          "description": "AWS region.",
          "type": "string",
          "default": "us-east-1",
          "x-example": "us-east-1"
        },
        "access_key_id": {
          "description": "S3 access key ID.",
          "type": "string", "minLength": 1,
          "x-secret": true,
          "x-example": "AKIA..."
        },
        "secret_access_key": {
          "description": "S3 secret access key.",
          "type": "string", "minLength": 1,
          "x-secret": true,
          "x-example": "..."
        },
        "session_token": {
          "description": "S3 session token (for temporary credentials).",
          "type": "string",
          "x-secret": true
        },
        "custom_host": {
          "description": "Custom host for download URLs (e.g. CDN domain).",
          "type": "string",
          "example": "cdn.example.com"
        },
        "force_path_style": {
          "description": "Force path-style addressing (required for MinIO and most non-AWS S3).",
          "type": "boolean",
          "default": false,
          "x-example": true
        },
        "list_object_version": {
          "description": "S3 list API version: v1 or v2.",
          "type": "string",
          "default": "v1",
          "enum": ["v1", "v2"]
        },
        "placeholder": {
          "description": "Placeholder filename for empty directories.",
          "type": "string",
          "default": ".qrypt",
          "x-example": ".qrypt"
        },
        "root_path": {
          "description": "Root path prefix within the bucket.",
          "type": "string",
          "default": "/",
          "x-example": "/my-mount"
        },
        "sign_url_expire": {
          "description": "Presigned URL expiration duration.",
          "type": "string",
          "default": "4h",
          "x-example": "1h"
        }
      },
      "additionalProperties": false
    }
  }
}
